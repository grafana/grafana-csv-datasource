{
  "name": "grafana-csv-datasource",
  "version": "1.0.0",
  "description": "A Grafana data source for loading CSV data",
  "keywords": [
    "grafana",
    "csv"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "e2e": "playwright test",
    "lint": "eslint --cache .",
    "lint:fix": "yarn run lint --fix && prettier --write --list-different .",
    "server": "docker compose up --build",
    "sign": "npx --yes --ignore-scripts --package @grafana/sign-plugin@3.2.2 sign-plugin",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,go,md,mdx,yml,yaml,json,scss,css}\"",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit"
  },
  "homepage": "https://grafana.com/plugins/marcusolsson-csv-datasource",
  "bugs": "https://github.com/grafana/grafana-csv-datasource/issues",
  "repository": "github:grafana/grafana-csv-datasource",
  "author": {
    "name": "Grafana Labs",
    "url": "https://grafana.com"
  },
  "dependencies": {
    "@grafana/data": "13.1.1",
    "@grafana/i18n": "13.1.1",
    "@grafana/plugin-ui": "0.17.3",
    "@grafana/runtime": "13.1.1",
    "@grafana/schema": "13.1.1",
    "@grafana/ui": "13.1.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@changesets/cli": "2.31.1",
    "@emotion/css": "11.13.5",
    "@grafana/e2e-selectors": "13.1.1",
    "@grafana/eslint-config": "9.0.0",
    "@grafana/plugin-e2e": "3.10.0",
    "@grafana/sign-plugin": "3.3.3",
    "@grafana/tsconfig": "2.2.0",
    "@playwright/test": "1.61.1",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@swc/core": "1.15.46",
    "@swc/helpers": "0.5.23",
    "@swc/jest": "0.2.39",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.24",
    "@types/node": "25.9.5",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "8.65.0",
    "@typescript-eslint/parser": "8.65.0",
    "copy-webpack-plugin": "14.0.0",
    "cspell": "10.0.1",
    "css-loader": "7.1.4",
    "eslint": "9.39.5",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "63.2.0",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-webpack-plugin": "6.0.0",
    "fork-ts-checker-webpack-plugin": "9.1.0",
    "glob": "13.0.6",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "5.0.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "prettier": "3.9.6",
    "react-virtualized-auto-sizer": "2.0.3",
    "replace-in-file-webpack-plugin": "1.0.6",
    "rxjs": "7.8.2",
    "sass": "1.101.3",
    "sass-loader": "17.0.0",
    "style-loader": "4.0.0",
    "swc-loader": "0.2.7",
    "terser-webpack-plugin": "5.6.1",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "webpack": "5.108.4",
    "webpack-cli": "7.2.1",
    "webpack-livereload-plugin": "3.0.2",
    "webpack-subresource-integrity": "5.1.0",
    "webpack-virtual-modules": "0.6.2"
  },
  "packageManager": "yarn@4.17.1",
  "engines": {
    "node": ">=24"
  }
}
